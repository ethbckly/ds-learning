import pandas as pd
import seaborn as sns

df = sns.load_dataset('titanic')
# print(df.head())
# print(df.info(), df.isnull().sum(), df.describe())
# print(df['age'].describe())

# TASK 1 - How many passengers were in each class? 

print(df['pclass'].value_counts())
# Class 3 - 491, Class 2 - 184, Class 1 - 216

# TASK 2 - What was the survival rate by sex
print(df.groupby('sex').agg({
    'survived': 'mean'
}))

# Out of the survivors it was 74% female, 19% male

# TASK 3 - Fill missing ages with the median age
median_age = df['age'].median()
df['age'] = df['age'].fillna(median_age)

# TASK 4 - Drop the deck column due to way to many nulls
df = df.drop('deck', axis=1)

# TASK 5 - Create a new column 'fare_per_class' - fare divided by pclass
df['fare_per_class'] = df['fare'] / df['pclass']
